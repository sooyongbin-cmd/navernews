# 네이버 개발자센터에서 발급받은 뉴스 검색 API 자격 증명
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 검색 결과 3건을 5분 동안 서명하는 32자 이상의 임의 문자열
# 생성 예: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BRIEFING_SIGNING_SECRET=replace_with_at_least_32_random_characters

# 무료 대상 모델만 허용됩니다. 다른 값은 서버에서 차단합니다.
AI_MODEL=openai/gpt-5-mini

# 로컬 개발에서만 필요합니다. Vercel 배포는 OIDC 인증을 사용할 수 있습니다.
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key

# 기존 Gateway와 별개로 Google Gemini API를 직접 호출할 때 사용합니다.
# 브라우저나 Git 저장소에 실제 키를 노출하지 마세요.
GEMINI_API_KEY=your_google_ai_studio_api_key

# 무료 티어 대상 모델만 허용되며 다른 값은 서버에서 차단합니다.
GEMINI_MODEL=gemini-3.5-flash
